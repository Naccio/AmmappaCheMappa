{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "source",
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "target": "ESNext",
    "sourceMap": true,
    "removeComments": true,
    "strict": true
  },
  "include": [
    "source/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}